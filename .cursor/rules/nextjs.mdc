тФВ   тФЬтФАтФА modal.tsx
тФВ   тФФтФАтФА index.ts          # Export all UI components
тФЬтФАтФА layout/               # Layout components
тФВ   тФЬтФАтФА header.tsx
тФВ   тФЬтФАтФА footer.tsx
тФВ   тФЬтФАтФА sidebar.tsx
тФВ   тФФтФАтФА index.ts
тФЬтФАтФА forms/                # Form-related components
тФВ   тФЬтФАтФА form-field.tsx
тФВ   тФЬтФАтФА form-submit.tsx
тФВ   тФФтФАтФА index.ts
